---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  subtitle?: string;
  effectiveDate?: string;
  lastUpdated?: string;
  ctaTitle?: string;
}

const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL || 'hello@lawh.app';
const { title, subtitle, effectiveDate, lastUpdated, ctaTitle = 'Have questions?' } = Astro.props;
---

<BaseLayout title={`${title} - Lawh`}>
  <div class="min-h-screen bg-background">
    <header class="relative bg-gradient-to-br from-primary-dark to-primary py-8 md:py-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(255,255,255,0.08),transparent_60%)]"></div>
      <div class="relative max-w-5xl mx-auto px-4">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-white/60 hover:text-white transition text-sm mb-4"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Home
        </a>
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3">
          <div>
            <h1 class="text-2xl md:text-3xl font-bold text-white">{title}</h1>
            {subtitle && <p class="mt-1 text-sm text-white/50">{subtitle}</p>}
          </div>
          {(effectiveDate || lastUpdated) && (
            <div class="text-xs text-white/40 md:text-right leading-relaxed">
              {effectiveDate && <div>Effective {effectiveDate}</div>}
              {lastUpdated && <div>Updated {lastUpdated}</div>}
            </div>
          )}
        </div>
      </div>
    </header>

    <div class="max-w-5xl mx-auto px-4 py-8 md:py-12 lg:flex lg:gap-10">
      <nav class="not-prose hidden lg:block lg:w-48 shrink-0">
        <div class="sticky top-8">
          <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted/60 mb-3">On this page</p>
          <ul id="toc-list" class="space-y-0.5 text-[13px] leading-snug list-none p-0 m-0">
          </ul>
        </div>
      </nav>

      <div class="lg:hidden mb-6">
        <details class="not-prose border border-background-alt rounded-lg">
          <summary class="px-4 py-2.5 text-sm font-medium text-text-muted cursor-pointer select-none">
            On this page
          </summary>
          <ul id="toc-list-mobile" class="px-4 pb-3 space-y-0.5 text-[13px] leading-snug list-none m-0">
          </ul>
        </details>
      </div>

      <main class="min-w-0 flex-1">
        <article class="prose prose-lg max-w-none legal-prose text-justify">
          <slot />
        </article>

        <div class="mt-16 pt-8 border-t border-background-alt">
          <div class="bg-background-alt rounded-2xl p-8 text-center">
            <h3 class="text-lg font-semibold text-primary-dark">{ctaTitle}</h3>
            <p class="mt-2 text-text-muted">We're here to help. Reach out to our team.</p>
            <a
              href={`mailto:${contactEmail}`}
              class="mt-4 inline-flex items-center gap-2 bg-primary text-white px-6 py-2.5 rounded-full font-medium hover:bg-primary-dark transition no-underline"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {contactEmail}
            </a>
          </div>
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<script>
  function buildToc() {
    const article = document.querySelector('article');
    if (!article) return;

    const headings = article.querySelectorAll('h2');
    const tocList = document.getElementById('toc-list');
    const tocListMobile = document.getElementById('toc-list-mobile');

    headings.forEach((heading) => {
      const id = heading.textContent?.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || '';
      heading.id = id;

      const label = heading.textContent?.replace(/^\d+\.\s*/, '') || '';

      const createLink = () => {
        const li = document.createElement('li');
        li.style.listStyle = 'none';
        li.style.padding = '0';
        li.style.margin = '0';
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = label;
        a.className = 'toc-link';
        li.appendChild(a);
        return li;
      };

      tocList?.appendChild(createLink());
      tocListMobile?.appendChild(createLink());
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            document.querySelectorAll('.toc-link').forEach(a => {
              a.classList.remove('active');
            });
            document.querySelectorAll(`a[href="#${entry.target.id}"]`).forEach(a => {
              a.classList.add('active');
            });
          }
        });
      },
      { rootMargin: '-80px 0px -80% 0px' }
    );

    headings.forEach(h => observer.observe(h));
  }

  buildToc();
</script>

<style is:global>
  .toc-link {
    display: block;
    padding: 6px 12px;
    border-radius: 6px;
    color: var(--color-text-muted);
    text-decoration: none !important;
    transition: all 0.15s ease;
    font-size: 13px;
    line-height: 1.4;
  }

  .toc-link:hover {
    color: var(--color-primary);
    background-color: var(--color-background-alt);
  }

  .toc-link:active {
    background-color: color-mix(in srgb, var(--color-primary) 10%, transparent);
  }

  .toc-link.active {
    color: var(--color-primary);
    font-weight: 500;
    background-color: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }
</style>
