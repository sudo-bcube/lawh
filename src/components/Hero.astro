---
const iosUrl = import.meta.env.PUBLIC_IOS_APP_URL || '#';
---

<section id="home" class="relative pt-24 pb-16 md:pt-32 md:pb-24 overflow-hidden bg-[#1a1a2e]">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      <div class="flex-1 text-center lg:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
          Stay in sync with moments that move your faith.
        </h1>

        <p class="mt-6 text-lg md:text-xl text-white/70 max-w-xl mx-auto lg:mx-0">
          Instantly recognize any Qur'an recitation and follow it without losing your place.
        </p>

        <div class="mt-8 flex flex-wrap gap-4 justify-center lg:justify-start">
          <a href={iosUrl} target="_blank" rel="noopener noreferrer"
             class="px-8 py-3 bg-[#4361ee] text-white rounded-lg font-medium hover:bg-[#3651d4] transition-colors no-underline">
            Order Now
          </a>
          <a href="#features"
             class="px-8 py-3 border border-white/30 text-white rounded-lg font-medium hover:bg-white/10 transition-colors no-underline">
            Learn More
          </a>
        </div>
      </div>

      <div class="flex-1 relative">
        <div class="relative max-w-sm mx-auto">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-[3rem] blur-3xl -z-10"></div>
          <div class="relative">
            <img
              src="/images/screenshots/app-screenshot-4.png"
              alt="Lawh app showing Ayatul Kursi with Arabic text, transliteration, and translation"
              class="rounded-[2rem] shadow-2xl w-full"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
