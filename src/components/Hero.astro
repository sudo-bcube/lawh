---
import AppStoreButtons from './AppStoreButtons.astro';
---

<section id="home" class="relative pt-24 pb-16 md:pt-32 md:pb-24 overflow-hidden bg-primary-dark">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      <div class="flex-1 text-center lg:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
          Stay in sync with moments that move your faith.
        </h1>

        <p class="mt-6 text-lg md:text-xl text-white/70 max-w-xl mx-auto lg:mx-0">
          Instantly recognize any Qur'an recitation and follow it without losing your place.
        </p>

        <div class="mt-8 flex justify-center lg:justify-start">
          <AppStoreButtons variant="light" />
        </div>
      </div>

      <div class="flex-1 relative">
        <div class="relative max-w-[250px] md:max-w-[280px] mx-auto">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-[3rem] blur-3xl -z-10"></div>
          <div class="relative">
            <img
              src="/images/screenshots/app-screenshot-1.jpeg"
              alt="Lawh app home screen"
              class="rounded-[2rem] shadow-2xl w-full hero-image hero-image-1"
            />
            <img
              src="/images/screenshots/app-screenshot-2.jpeg"
              alt="Lawh app recording in progress"
              class="rounded-[2rem] shadow-2xl w-full hero-image hero-image-2 absolute inset-0"
            />
            <img
              src="/images/screenshots/app-screenshot-4.png"
              alt="Lawh app showing verse result with Arabic text, transliteration, and translation"
              class="rounded-[2rem] shadow-2xl w-full hero-image hero-image-3 absolute inset-0"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-image {
    animation: fadeThree 9s infinite;
    opacity: 0;
  }

  .hero-image-1 {
    animation-delay: 0s;
  }

  .hero-image-2 {
    animation-delay: 3s;
  }

  .hero-image-3 {
    animation-delay: 6s;
  }

  @keyframes fadeThree {
    0%, 5% { opacity: 0; }
    10%, 28% { opacity: 1; }
    33%, 100% { opacity: 0; }
  }
</style>
