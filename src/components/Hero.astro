---
import AppStoreButtons from './AppStoreButtons.astro';
---

<section id="home" class="relative pt-24 pb-16 md:pt-32 md:pb-24 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-secondary/5 -z-10"></div>

  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      <div class="flex-1 text-center lg:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-text leading-tight">
          Be in sync with moments that move your faith.
        </h1>

        <p class="mt-6 text-lg md:text-xl text-text-muted max-w-xl mx-auto lg:mx-0">
          Feel focused, connected, and fully present with every Quran verse without distraction or friction.
        </p>

        <p class="mt-4 text-sm text-primary font-medium">
          *All recitations recognized, whatever the style.
        </p>

        <div class="mt-8">
          <AppStoreButtons />
        </div>
      </div>

      <div class="flex-1 relative">
        <div class="relative max-w-sm mx-auto">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-[3rem] blur-3xl -z-10"></div>
          <img
            src="/images/screenshots/app-screenshot-1.jpeg"
            alt="Lawh app showing Quran verse recognition"
            class="rounded-[2rem] shadow-2xl w-full"
          />
        </div>
      </div>
    </div>
  </div>
</section>
