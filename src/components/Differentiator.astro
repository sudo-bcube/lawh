---
import AppStoreButtons from './AppStoreButtons.astro';
---

<section class="py-20 md:py-28 bg-primary-dark">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">
      The Qur'an comes first.
    </h2>

    <p class="mt-6 text-lg md:text-xl text-white/70 max-w-2xl mx-auto">
      Lawh exists for one reason: to help you stay connected to it.
    </p>

    <p class="mt-2 text-white/50">
      Free to begin. Premium when you're ready.
    </p>

    <div class="mt-10 flex justify-center">
      <AppStoreButtons variant="light" />
    </div>
  </div>
</section>
