---
const steps = [
  {
    number: 1,
    title: 'Hear a verse.',
    description: 'During recitation, lectures, or daily reflection.',
    image: '/images/screenshots/app-screenshot-1.jpeg',
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" /></svg>`
  },
  {
    number: 2,
    title: 'Tap to record.',
    description: 'Instantly capture the verse with Lawh.',
    image: '/images/screenshots/app-screenshot-2.jpeg',
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243l-1.59-1.59" /></svg>`
  },
  {
    number: 3,
    title: 'See it instantly.',
    description: 'Arabic text, transliteration, and translation appear so you can reflect or share.',
    image: '/images/screenshots/app-screenshot-4.png',
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`
  }
];
---

<section id="how-it-works" class="py-16 md:py-24 bg-[#f5f0eb]">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-text text-center">
      Stay in sync with every verse.
    </h2>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      {steps.map(step => (
        <div class="flex flex-col items-center text-center">
          <div class="relative">
            <span class="absolute -top-3 -right-3 w-8 h-8 bg-[#b8a080] text-white rounded-full flex items-center justify-center font-bold text-sm z-10">
              {step.number}
            </span>
            <div class="w-48 h-48 bg-white rounded-2xl shadow-sm overflow-hidden flex items-center justify-center">
              <img
                src={step.image}
                alt={step.title}
                class="w-full h-full object-cover"
              />
            </div>
          </div>
          <div class="mt-4 flex items-center gap-2 text-[#b8a080]">
            <Fragment set:html={step.icon} />
          </div>
          <h3 class="mt-2 text-lg font-semibold text-text">{step.title}</h3>
          <p class="mt-1 text-sm text-text-muted max-w-xs">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
