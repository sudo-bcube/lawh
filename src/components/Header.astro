---
const navLinks = [
  { href: '#features', label: 'Features' },
  { href: '#how-it-works', label: 'How It Works' },
  { href: '#pricing', label: 'Pricing' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center">
      <img src="/logos/logo-full-horizontal.svg" alt="Lawh" class="h-8" />
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="text-text-muted hover:text-primary transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="#download" class="hidden md:inline-flex px-5 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors font-medium">
      Download App
    </a>

    <button id="mobile-menu-btn" class="md:hidden p-2 text-text" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100">
    <ul class="px-4 py-4 space-y-4">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="block text-text-muted hover:text-primary transition-colors">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="#download" class="block px-5 py-2 bg-primary text-white rounded-lg text-center font-medium">
          Download App
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>
