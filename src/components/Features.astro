---
const features = [
  {
    icon: 'mic',
    title: 'Instant recognition',
    description: 'Record any Quran verse and see instant Arabic text, transliteration, and translation, no matter the recitation style.'
  },
  {
    icon: 'waveform',
    title: 'Real-time flow',
    description: "Follow recitations naturally. Intonation, dialect, or tribal variation won't get in the way."
  },
  {
    icon: 'search',
    title: 'Effortless search',
    description: 'Find any verse or surah quickly, even if you only remember part of it.'
  },
  {
    icon: 'share',
    title: 'Read and share',
    description: "Explore the Qur'an at your own pace, or share meaningful verses with loved ones."
  },
  {
    icon: 'heart',
    title: 'Stay present',
    description: 'Every interaction keeps you in sync with your recitation so you can reflect, focus, and feel the words fully.'
  }
];

const iconPaths: Record<string, string> = {
  mic: 'M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.91-3c-.49 0-.9.36-.98.85C16.52 14.2 14.47 16 12 16s-4.52-1.8-4.93-4.15c-.08-.49-.49-.85-.98-.85-.61 0-1.09.54-1 1.14.49 3 2.89 5.35 5.91 5.78V20c0 .55.45 1 1 1s1-.45 1-1v-2.08c3.02-.43 5.42-2.78 5.91-5.78.1-.6-.39-1.14-1-1.14z',
  waveform: 'M3 12h2v4H3v-4zm4-6h2v16H7V6zm4 3h2v10h-2V9zm4-3h2v16h-2V6zm4 6h2v4h-2v-4z',
  search: 'M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z',
  share: 'M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z',
  heart: 'M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z'
};
---

<section id="features" class="py-16 md:py-24 bg-background-alt">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-text text-center">
      Helping your Iman grow in more ways than one
    </h2>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature, index) => (
        <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
              <path d={iconPaths[feature.icon]} />
            </svg>
          </div>
          <h3 class="mt-5 text-xl font-semibold text-text">{feature.title}</h3>
          <p class="mt-3 text-text-muted">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
